ENVIRONMENT=development

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Supabase Postgres
DATABASE_URL=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=
SUPABASE_DB_NAME=
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_SSL_MODE=

# Local POC: keep false because project uses newer ECC JWT signing keys.
SUPABASE_VERIFY_JWT=
SUPABASE_JWT_SECRET=

# MongoDB
MONGODB_URI=
MONGODB_DB_NAME=

# WhatsApp (Meta)
META_PORTFOLIO_ADMIN_API_KEY=
WA_BUSINESS_ACC_ID=
WA_SENDER_ID=

# Postgres - Supabase
SUPABASE_DB_HOST=db.<your-project-ref>.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<your_database_password>
SUPABASE_SSL_MODE=require
SUPABASE_VERIFY_JWT=false
SUPABASE_JWT_SECRET=<optional_for_backend_token_verification>

# Supabase Auth (for backend auth layer)
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your_service_role_key>
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_GRAPH_API_VERSION=
